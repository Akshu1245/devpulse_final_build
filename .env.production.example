# DevPulse Production Environment Variables
# ==========================================
# SECURITY: Never commit this file with real values to version control
# Copy to .env.production and fill in production values

# Database
POSTGRES_USER=devpulse_admin
POSTGRES_PASSWORD=CHANGE_ME_TO_SECURE_PASSWORD_32_CHARS
POSTGRES_DB=devpulse

# Redis (optional password)
REDIS_PASSWORD=

# Grafana
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=CHANGE_ME_TO_SECURE_PASSWORD

# JWT (minimum 32 characters, high entropy)
JWT_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_base64_48

# Stripe (get from Stripe Dashboard)
STRIPE_SECRET_KEY=REDACTED_STRIPE_SECRET_KEY
STRIPE_WEBHOOK_SECRET=REDACTED_STRIPE_WEBHOOK_SECRET

# Email (for notifications)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@devpulse.in
SMTP_PASS=CHANGE_ME

# Slack (for alerts)
SLACK_WEBHOOK_URL=REDACTED_SLACK_WEBHOOK_URL

# Application
NODE_ENV=production
PORT=3000
CORS_ORIGINS=https://app.devpulse.in,https://devpulse.in
CSRF_STRATEGY=double-submit
