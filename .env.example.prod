# DevPulse High-Availability Environment Configuration
# Copy this file to .env and fill in your values

# ==================== DATABASE ====================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-secure-postgres-password-change-me
POSTGRES_DB=devpulse

# ==================== REDIS ====================
REDIS_PASSWORD=your-secure-redis-password-change-me

# ==================== MONITORING ====================
GRAFANA_PASSWORD=your-secure-grafana-password-change-me

# ==================== EXTERNAL SERVICES ====================
# API Keys and secrets for integrations
OPENAI_API_KEY=sk-...
STRIPE_API_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ==================== APPLICATION ====================
NODE_ENV=production
LOG_LEVEL=info
DEBUG=false

# ==================== SECURITY ====================
# CORS and domain settings
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
JWT_SECRET=your-secure-jwt-secret-change-me
CSRF_STRATEGY=double-submit

# ==================== EMAILS ====================
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=SG....

# ==================== BACKUPS ====================
BACKUP_SCHEDULE=0 2 * * *  # 2 AM daily
BACKUP_RETENTION_DAYS=30
